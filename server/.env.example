MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
PORT=8080

# Required in production for Instagram handle validation and profile picture sync.
# Create a Meta app with Instagram Graph access and provide:
# - an access token with business_discovery access
# - your Instagram Business Account ID
INSTAGRAM_GRAPH_ACCESS_TOKEN=your_instagram_graph_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
